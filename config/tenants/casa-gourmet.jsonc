{
  "agents": {
    "defaults": {
      "sandbox": {
        "mode": "all",
        "scope": "session",
        "workspaceAccess": "ro",
        "docker": {
          "network": "bridge"
        }
      }
    },
    "list": [
      {
        "id": "main"
      },
      {
        "id": "lucia",
        "name": "Lucia",
        "workspace": "/home/openclaw/.openclaw/workspace/agents/lucia",
        "agentDir": "/home/openclaw/.openclaw/agents/lucia/agent",
        "model": {
          "primary": "openai/gpt-5-nano"
        },
        "tools": {
          "profile": "messaging",
          "deny": ["gateway", "cron", "group:nodes", "bash", "browser"]
        },
        "subagents": {
          "allowAgents": []
        },
        "routing": [
          {
            "channel": "telegram",
            "account": "lucia"
          }
        ]
      }
    ]
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "dmPolicy": "allowlist",
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowFrom": [
        6041283426
      ],
      "groupPolicy": "disabled",
      "groupAllowFrom": [],
      "streaming": "partial",
      // Lucia's separate Telegram bot
      "accounts": {
        "lucia": {
          "botToken": "${LUCIA_TELEGRAM_BOT_TOKEN}",
          "enabled": true,
          "dmPolicy": "allowlist",
          "allowFrom": [6041283426],
          "groupPolicy": "disabled",
          "streaming": "partial"
        }
      }
    }
  },

  // Mem0: per-tenant memory isolation
  "plugins": {
    "entries": {
      "openclaw-mem0": {
        "config": {
          "userId": "casa-gourmet",
          "oss": {
            "vectorStore": {
              "config": {
                "collection_name": "mem0_casa_gourmet",
                "user": "sa-casa-gourmet@sugato-489514.iam"
              }
            }
          }
        }
      }
    }
  }
}