// Sugato (internal) — security overrides
//
// $include'd by Sugato's openclaw.json on top of base.jsonc.
// Because this is our own agent: full access, sandbox off.
{
  // Full tool access for internal ops
  "tools": {
    "profile": "full",
    "deny": []
  },

  // Allow config changes from chat (internal testing)
  "commands": {
    "config": true,
    "bash": true
  },

  "channels": {
    "defaults": {},
    // WhatsApp: dedicated number, pairing-based DM access
    "whatsapp": {
      "enabled": true,
      "dmPolicy": "pairing",
      "groupPolicy": "allowlist"
    }
  },

  // Primary model override
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-5.4"
      }
    }
  },

  // Mem0: per-tenant memory isolation
  // ACP: sub-agent spawning (sessions_spawn / sessions_send)
  "plugins": {
    "entries": {
      "acpx": {
        "enabled": true
      },
      // mem0 disabled: vectorStore provider config incomplete — fix in issue #16
      "openclaw-mem0": {
        "enabled": false
      }
    }
  }
}
